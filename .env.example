# ── Family Hub — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and fill in your real values.
# Get these from https://emailjs.com after:
#   1. Creating a free account
#   2. Adding an Email Service (Gmail recommended)
#   3. Creating an Email Template with {{to_email}}, {{otp_code}}, {{app_name}}
#   4. Copying your Public Key from Account → General
#
# Without these set, the app runs in dev mode:
# the verification code is shown in the browser console only.

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxx
